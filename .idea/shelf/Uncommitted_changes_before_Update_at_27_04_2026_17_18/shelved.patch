+def draw_text(text, font, color, surface, x, y, center=False):
+    img = font.render(str(text), True, color)
+    rect = img.get_rect()
+    if center:
+        rect.center = (x, y)
+    else:
+        rect.topleft = (x, y)
+    surface.blit(img, rect)
